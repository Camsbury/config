{:structural true
 :doc        "Shared structural face layer for EDN-sourced doom themes."

 :faces
 {:cursor                   {:background :magenta}
  :lazy-highlight           {:background         :violet :foreground :base0
                             :distant-foreground :base0  :bold       true}
  :line-number              {:&override          true :foreground :base5
                             :distant-foreground :unspecified}
  :line-number-current-line {:&override          true :foreground :base7
                             :distant-foreground :unspecified}
  :mode-line                {:background :modeline-bg :foreground :modeline-fg
                             :box        false}
  :mode-line-inactive       {:background :modeline-bg-inactive
                             :foreground :modeline-fg-alt :box false}
  :isearch                  {:foreground :base0 :background :green}
  :fill-column-indicator    {:foreground :base2}

  :css-proprietary-property          {:foreground :keywords}
  :doom-modeline-bar                 {:background :green}
  :doom-modeline-buffer-file         {:inherit :mode-line-buffer-id :weight :bold}
  :doom-modeline-buffer-path         {:inherit :bold :foreground :green}
  :doom-modeline-buffer-project-root {:foreground :green :weight :bold}
  :doom-modeline-buffer-modified     {:inherit :bold :foreground :orange}
  :ediff-fine-diff-A                 {:background [:darken :magenta 0.7] :weight :bold}
  :magit-diff-added                  {:foreground :green :background [:darken :green 0.9] :extend true}
  :magit-diff-added-highlight        {:foreground [:lighten :green 0.1] :background [:darken :green 0.8] :extend true}
  :magit-diff-removed                {:foreground :red :background [:darken :red 0.9] :extend true}
  :magit-diff-removed-highlight      {:foreground [:lighten :red 0.1] :background [:darken :red 0.8] :extend true}
  :evil-snipe-first-match-face       {:foreground :base0 :background :green}
  :evil-snipe-matches-face           {:foreground :green :underline true}
  :flycheck-error                    {:underline {:style :wave :color :red} :background :base1}
  :flycheck-warning                  {:underline {:style :wave :color :yellow} :background :base1}
  :flycheck-info                     {:underline {:style :wave :color :green} :background :base1}
  :markdown-blockquote-face          {:inherit :italic :foreground :dark-blue}
  :markdown-list-face                {:foreground :magenta}
  :markdown-pre-face                 {:foreground :cyan}
  :markdown-link-face                {:inherit :bold :foreground :blue}
  :markdown-code-face                {:&override true :background [:lighten :base2 0.045]}
  :org-ellipsis                      {:foreground :orange}
  :org-tag                           {:foreground :yellow :bold false}
  :org-quote                         {:&override true :foreground :base7}
  :org-todo                          {:foreground :yellow :bold :inherit}
  :org-list-dt                       {:foreground :yellow}

  ;; eca-chat context-usage bar.  The bar reads each face's FOREGROUND and
  ;; paints it as the segment color (a space :background in GUI frames, the
  ;; ?block glyph fg in terminals), so every entry here sets :foreground even
  ;; though the free region reads as a "background".  Server-sent hex is
  ;; stripped in config/services/eca/colors.el so these actually apply.
  :eca-chat-context-system-prompt-face    {:foreground :blue}
  :eca-chat-context-rules-face            {:foreground :red}
  :eca-chat-context-skills-face           {:foreground :yellow}
  :eca-chat-context-agents-face           {:foreground :cyan}
  :eca-chat-context-tool-definitions-face {:foreground :yellow}
  :eca-chat-context-tool-calls-face       {:foreground :lavender}
  :eca-chat-context-conversation-face     {:foreground :green}
  :eca-chat-context-free-face             {:foreground :base4}}}
