{:structural true
 :doc "Shared structural face layer for EDN-sourced doom themes."

 :faces
 {:cursor         {:background :magenta}
  :lazy-highlight {:background :violet :foreground :base0
                   :distant-foreground :base0 :bold bold}
  :line-number    {:&override true :foreground :base5
                   :distant-foreground (quote unspecified)}
  :line-number-current-line {:&override true :foreground :base7
                             :distant-foreground (quote unspecified)}
  :mode-line
  {:background :modeline-bg :foreground :modeline-fg
   :box (if :-modeline-pad
            (quasiquote (:line-width (unquote :-modeline-pad) :color :modeline-bg)))}
  :mode-line-inactive
  {:background :modeline-bg-inactive :foreground :modeline-fg-alt
   :box (if :-modeline-pad
            (quasiquote (:line-width (unquote :-modeline-pad) :color :modeline-bg-inactive)))}
  :isearch        {:foreground :base0 :background :green}

  :centaur-tabs-active-bar-face {:background :green}
  :centaur-tabs-modified-marker-selected
  {:inherit (quote centaur-tabs-selected) :foreground :green}
  :centaur-tabs-modified-marker-unselected
  {:inherit (quote centaur-tabs-unselected) :foreground :green}
  :css-proprietary-property {:foreground :keywords}
  :doom-modeline-bar {:background :green}
  :doom-modeline-buffer-file {:inherit (quote mode-line-buffer-id) :weight (quote bold)}
  :doom-modeline-buffer-path {:inherit (quote bold) :foreground :green}
  :doom-modeline-buffer-project-root {:foreground :green :weight (quote bold)}
  :doom-modeline-buffer-modified {:inherit (quote bold) :foreground :orange}
  :ediff-fine-diff-A {:background (doom-blend :magenta :bg 0.3) :weight (quote bold)}
  :evil-search-highlight-persist-highlight-face {:background :violet}
  :evil-snipe-first-match-face {:foreground :base0 :background :green}
  :evil-snipe-matches-face     {:foreground :green :underline t}
  :flycheck-error   {:underline (quasiquote (:style wave :color (unquote :red)))    :background :base1}
  :flycheck-warning {:underline (quasiquote (:style wave :color (unquote :yellow))) :background :base1}
  :flycheck-info    {:underline (quasiquote (:style wave :color (unquote :green)))  :background :base1}
  :helm-swoop-target-line-face {:foreground :magenta :inverse-video t}
  :ivy-current-match {:background :base2}
  :ivy-minibuffer-match-face-1 {:background :base1 :foreground :base4}
  :markdown-blockquote-face {:inherit (quote italic) :foreground :dark-blue}
  :markdown-list-face {:foreground :magenta}
  :markdown-pre-face  {:foreground :cyan}
  :markdown-link-face {:inherit (quote bold) :foreground :blue}
  :markdown-code-face {:&override true :background (doom-lighten :base2 0.045)}
  :neo-dir-link-face   {:foreground :cyan}
  :neo-expand-btn-face {:foreground :magenta}
  :org-ellipsis {:foreground :orange}
  :org-tag      {:foreground :yellow :bold nil}
  :org-quote    {:&override true :foreground :base7}
  :org-todo     {:foreground :yellow :bold (quote inherit)}
  :org-list-dt  {:foreground :yellow}}}
